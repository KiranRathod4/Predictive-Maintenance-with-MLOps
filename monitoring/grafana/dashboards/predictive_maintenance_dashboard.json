{
  "uid": "pred-maintenance-v2",
  "title": "Predictive Maintenance — Live",
  "description": "Real-time metrics from FastAPI on Render. Make a prediction → watch the RUL graph spike.",
  "tags": ["mlops", "predictive-maintenance", "rul"],
  "timezone": "browser",
  "refresh": "10s",
  "schemaVersion": 38,
  "version": 1,
  "time": { "from": "now-1h", "to": "now" },

  "panels": [

    {
      "id": 1,
      "type": "stat",
      "title": "Total Predictions Made",
      "description": "Cumulative count of all /predict calls",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null }
            ]
          },
          "mappings": [],
          "unit": "short"
        }
      },
      "targets": [
        {
          "expr": "predictions_total",
          "legendFormat": "Predictions",
          "refId": "A",
          "instant": true
        }
      ]
    },

    {
      "id": 2,
      "type": "stat",
      "title": "Prediction Errors",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red",   "value": 1 }
            ]
          },
          "unit": "short"
        }
      },
      "targets": [
        {
          "expr": "prediction_errors_total",
          "legendFormat": "Errors",
          "refId": "A",
          "instant": true
        }
      ]
    },

    {
      "id": 3,
      "type": "stat",
      "title": "Active Requests Right Now",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "orange", "value": 5 },
              { "color": "red",    "value": 20 }
            ]
          },
          "unit": "short"
        }
      },
      "targets": [
        {
          "expr": "active_requests",
          "legendFormat": "Active",
          "refId": "A",
          "instant": true
        }
      ]
    },

    {
      "id": 4,
      "type": "stat",
      "title": "Scrape Target Up",
      "description": "1 = Prometheus is successfully scraping the API",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "textMode": "value_and_name"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",   "value": null },
              { "color": "green", "value": 1 }
            ]
          },
          "mappings": [
            { "options": { "0": { "text": "DOWN" }, "1": { "text": "UP" } }, "type": "value" }
          ]
        }
      },
      "targets": [
        {
          "expr": "up{job=~\"predictive-maintenance.*\"}",
          "legendFormat": "API",
          "refId": "A",
          "instant": true
        }
      ]
    },

    {
      "id": 5,
      "type": "timeseries",
      "title": "⚡ Predicted RUL Values — Make a Prediction to See This Spike",
      "description": "Average predicted Remaining Useful Life over a 2-minute window. Each prediction you make will cause a data point here.",
      "gridPos": { "x": 0, "y": 4, "w": 24, "h": 10 },
      "options": {
        "tooltip": { "mode": "multi", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 20,
            "spanNulls": false,
            "showPoints": "always",
            "pointSize": 6,
            "drawStyle": "line",
            "gradientMode": "opacity"
          },
          "unit": "short",
          "displayName": "Avg RUL (cycles)"
        }
      },
      "targets": [
        {
          "expr": "rate(prediction_value_sum[2m]) / rate(prediction_value_count[2m])",
          "legendFormat": "Average RUL (2m)",
          "refId": "A"
        }
      ]
    },

    {
      "id": 6,
      "type": "timeseries",
      "title": "HTTP Request Rate — All Endpoints",
      "gridPos": { "x": 0, "y": 14, "w": 12, "h": 8 },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["sum"] }
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "auto"
          },
          "unit": "reqps"
        }
      },
      "targets": [
        {
          "expr": "rate(http_requests_total[2m])",
          "legendFormat": "{{method}} {{endpoint}} ({{status}})",
          "refId": "A"
        }
      ]
    },

    {
      "id": 7,
      "type": "timeseries",
      "title": "Request Latency — p50 & p95",
      "gridPos": { "x": 12, "y": 14, "w": 12, "h": 8 },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          }
        }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(http_request_duration_seconds_bucket[2m]))",
          "legendFormat": "p95 — {{endpoint}}",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.50, rate(http_request_duration_seconds_bucket[2m]))",
          "legendFormat": "p50 — {{endpoint}}",
          "refId": "B"
        }
      ]
    },

    {
      "id": 8,
      "type": "timeseries",
      "title": "Prediction Error Rate",
      "gridPos": { "x": 0, "y": 22, "w": 12, "h": 7 },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "fixedColor": "red", "mode": "fixed" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 20
          }
        }
      },
      "targets": [
        {
          "expr": "rate(prediction_errors_total[2m])",
          "legendFormat": "Errors/sec",
          "refId": "A"
        }
      ]
    },

    {
      "id": 9,
      "type": "gauge",
      "title": "Predictions / Second (last 5m)",
      "gridPos": { "x": 12, "y": 22, "w": 12, "h": 7 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "min": 0,
          "max": 5,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 2 },
              { "color": "red",    "value": 4 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "rate(predictions_total[5m])",
          "legendFormat": "Rate",
          "refId": "A"
        }
      ]
    }

  ]
}